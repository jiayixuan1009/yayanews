# ── Database & Cache (强烈建议走阿里云 VPC 内网 IP) ──
DATABASE_URL="postgresql://yayanews_super:<REDACTED>@192.168.x.x:5432/yayanews"
REDIS_URL="redis://:<REDACTED>@192.168.x.x:6379"

# ── Site（前端打包读入，改后需重新 npm run build / 重建镜像）──
NEXT_PUBLIC_SITE_URL=https://yayanews.cryptooptiontool.com
NEXT_PUBLIC_PARENT_SITE=https://www.biyapay.com
NEXT_PUBLIC_TRADING_SITE=https://invest.biyapay.com

# ── LLM（主线路 + 兜底线路，主线路失败自动切换）──
LLM_BASE_URL=https://openrouter.fans/v1
LLM_API_KEY=your-primary-llm-api-key
LLM_MODEL=deepseek-chat
LLM_REASONER_MODEL=deepseek-reasoner
# 兜底线路（可选，主线路不可用时自动降级）
LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
LLM_FALLBACK_API_KEY=your-fallback-llm-api-key
LLM_FALLBACK_MODEL=deepseek-chat

# ── News Data APIs ──
FINNHUB_KEY=your-finnhub-key
MARKETAUX_KEY=your-marketaux-key
CRYPTOCOMPARE_KEY=your-cryptocompare-key

# ── Pipeline（爬虫/调度；生产可调高 BATCH_SIZE / FLASH_CONCURRENCY）──
BATCH_SIZE=20
FLASH_CONCURRENCY=5
FLASH_TRANSLATE_BATCH=8

# ── Admin ──
ADMIN_API_TOKEN=your-secure-admin-token-here

# ── 图库 / 封面 / 生图（仅服务端 Pipeline 读取）──
# 安全：不要加 NEXT_PUBLIC_ 前缀；不要提交含真实密钥的 .env；勿把密钥贴进聊天或 Git。
# 若密钥曾泄露，请立即在各平台轮换（Revoke 旧 Key）。
#
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=
# Unsplash: 搜索/拉图一般用 Access Key；Secret 仅 OAuth，勿暴露给浏览器
# https://unsplash.com/documentation
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
# 部分集成会用到 Application ID（非 Access Key）；没有则留空
UNSPLASH_APPLICATION_ID=
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# 文生图（可选；仅服务端）
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=dall-e-3
# COVER_IMAGE_GEN=0
#
# 为已发布文章批量写库封面 URL（读 Key，不落盘密钥）：
#   npm run covers:assign
#   npm run covers:assign -- --dry-run
#   npm run covers:assign -- --force --limit=5

# ── 统计与站长验证（NEXT_PUBLIC_ 需重新 build 后生效）──
# Google Analytics 4 衡量 ID：管理 → 数据流 → 衡量 ID，格式 G-XXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XM5TYCGL732

# 后台「GA 流量」图表：GA4 Data API（仅服务端，与前台 gtag 衡量 ID 是两套配置）
# 1) GCP 创建服务账号 JSON，启用「Google Analytics Data API」
# 2) GA4 管理 → 媒体资源访问管理 → 添加用户 → 服务账号邮箱 → 角色「查看者」
# 3) GA4 管理 → 媒体资源设置 → 数字资源 ID（仅数字）
GA4_PROPERTY_ID=529230739
# 推荐：将整份 JSON base64 成一行（勿提交 Git）：  base64 -w0 sa.json
# GA4_CREDENTIALS_BASE64=
# 或服务器上设置文件路径： GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# 或单行 JSON（慎用转义）： GA4_CREDENTIALS_JSON=

# Bing 广告 UET：UET 标记里的 ti 数字；仅投广/转化追踪需要
# NEXT_PUBLIC_BING_UET_ID=12345678

# Microsoft Clarity（可选，热力图/会话录屏）
# NEXT_PUBLIC_MS_CLARITY_ID=xxxxxxxxxx

# Search Console：设置 → 添加资源 → HTML 标签 → content 里一长串
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=vG9GwN_MFqx35CiRPLw7POt6WxmCN0hllAizS6DwS3Mxxxxxxxx

# Bing Webmaster：添加站点 → HTML 标签 → msvalidate.01 的 content
# NEXT_PUBLIC_BING_SITE_VERIFICATION=xxxxxxxx

# ── 索引通知（Pipeline 入库后可选）──
# 不设 INDEXING_WEBHOOK_URL 时，Pipeline 不会 POST 任何 webhook（避免默认打 localhost 刷 500 日志）。
# 生产若已配置 Google Indexing API 凭据与 Web 路由，可填线上绝对地址：
# INDEXING_WEBHOOK_URL=https://yayanews.cryptooptiontool.com/api/webhooks/indexing
# INDEXING_WEBHOOK_SECRET=与 apps/web 内 INDEXING_WEBHOOK_SECRET 一致
# 本地联调示例：INDEXING_WEBHOOK_URL=http://127.0.0.1:3000/api/webhooks/indexing

# ── IndexNow（Bing/Yandex 快速收录）──
# key 字符串需与服务器 public/{key}.txt 文件名一致
# 生成方法：openssl rand -hex 16
INDEXNOW_KEY=your-indexnow-key-here

# ── 进程与后台执行环境配置 ──

# PM2 / Ecosystem 配置：如果要让 PM2 一起启动 Python 爬虫，必须设为 true
# 默认仅启动 Web / Admin / Gateway，防止本地冲突
ENABLE_PYTHON_WORKERS=false

# 用来指定爬虫使用的 Python 可执行文件路径
# 若使用 `npm run setup:python`，虚拟环境在 apps/pipeline/.venv，可将 PYTHON_BIN 指向其 python
# 若不提供，默认 fallback 寻找 `python3`
PYTHON_BIN=/usr/bin/python3

# 第三方行情查询 Key
# COINGECKO_API_KEY=xxxxxxxx
